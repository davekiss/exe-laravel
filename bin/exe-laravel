#!/usr/bin/env bash
set -euo pipefail

TEMPLATE_VM="laravel-template"
VERSION="0.4.0"

usage() {
    cat <<EOF
exe-laravel $VERSION — Laravel on exe.dev

Usage:
    exe-laravel new [name] [flags]    Create a new Laravel VM
    exe-laravel list                  List Laravel VMs
    exe-laravel ssh <name>            SSH into a VM
    exe-laravel open <name>           Open app URL in browser
    exe-laravel share <name>          Make app public
    exe-laravel unshare <name>        Make app private
    exe-laravel destroy <name>        Delete a VM
    exe-laravel clone <name> [new-name]  Copy a VM
    exe-laravel logs <name>           Tail Laravel logs
    exe-laravel artisan <name> <cmd...>  Run artisan command
    exe-laravel agent <name>          Open Shelley in browser

Starter kit flags for 'new':
    --react         Inertia + React
    --vue           Inertia + Vue
    --livewire      Livewire
    --pest          Use Pest for testing
    --typescript    Use TypeScript (with React/Vue)

Examples:
    exe-laravel new my-app                    # bare Laravel
    exe-laravel new my-app --react            # Inertia + React
    exe-laravel new my-app --vue --pest       # Vue + Pest
    exe-laravel new my-app --livewire         # Livewire

Workflow:
    Each VM is a live server. There is no deployment pipeline.
    Create a VM, SSH in, and start coding — changes are immediately
    live at https://<name>.exe.xyz.

    1. exe-laravel new my-app --react     # create VM + install Laravel
    2. ssh my-app.exe.xyz                 # SSH in and start building
    3. # edit code, run artisan/npm — app is always live

    The app lives at /home/exedev/app. PHP changes are instant.
    Run 'npm run build' after frontend changes.
    See AGENTS.md in the app root for full environment details.
EOF
}

cmd="${1:-help}"
shift || true

# Check exe.dev connectivity and registration
check_exe_dev() {
    local output
    output=$(ssh -o ConnectTimeout=5 -o StrictHostKeyChecking=no exe.dev version 2>&1) || true

    if echo "$output" | grep -qi "permission denied"; then
        echo "Error: SSH authentication failed."
        echo ""
        echo "Make sure your SSH key is added to exe.dev:"
        echo "  1. Run: ssh exe.dev"
        echo "  2. Follow the registration steps"
        echo ""
        echo "If you've already registered, make sure your SSH key is loaded:"
        echo "  ssh-add ~/.ssh/id_ed25519"
        exit 1
    fi

    if echo "$output" | grep -qi "complete registration"; then
        echo "Error: exe.dev registration incomplete."
        echo ""
        echo "Complete registration by running:"
        echo "  ssh exe.dev"
        echo ""
        echo "Then try again."
        exit 1
    fi
}

case "$cmd" in
    help|--help|-h) usage ;;
    new)
        name=""
        setup_flags=()

        # Parse arguments: first positional arg is the name, rest are flags
        for arg in "$@"; do
            if [[ "$arg" == --* ]]; then
                setup_flags+=("$arg")
            elif [[ -z "$name" ]]; then
                name="$arg"
            fi
        done

        check_exe_dev

        # Clone the golden template VM
        if [[ -z "$name" ]]; then
            echo "Error: VM name is required."
            echo "Usage: exe-laravel new <name> [flags]"
            exit 1
        fi

        echo "Creating VM..."
        ssh -o StrictHostKeyChecking=no exe.dev cp "$TEMPLATE_VM" "$name" || {
            echo "Error: Failed to create VM."
            echo ""
            echo "Make sure the template VM '$TEMPLATE_VM' exists."
            exit 1
        }

        # Point exe.dev proxy to nginx on port 8080
        ssh -o StrictHostKeyChecking=no exe.dev share port "$name" 8080 2>/dev/null || true

        # Wait for SSH to become available
        echo "Waiting for SSH..."
        ssh_ready=false
        for i in $(seq 1 30); do
            if ssh -o ConnectTimeout=2 -o StrictHostKeyChecking=no "${name}.exe.xyz" true 2>/dev/null; then
                ssh_ready=true
                break
            fi
            sleep 2
        done

        if [[ "$ssh_ready" != "true" ]]; then
            echo "Error: SSH did not become available after 60 seconds."
            echo "The VM was created but setup could not complete."
            echo ""
            echo "Try connecting manually:"
            echo "  ssh ${name}.exe.xyz"
            echo "  laravel-setup ${setup_flags[*]:-}"
            exit 1
        fi

        # Run laravel-setup on the VM with collected flags
        echo "Setting up Laravel..."
        ssh -o StrictHostKeyChecking=no "${name}.exe.xyz" "laravel-setup ${setup_flags[*]:-}" || {
            echo ""
            echo "Error: Laravel setup failed."
            echo ""
            echo "The VM is running. You can retry manually:"
            echo "  ssh ${name}.exe.xyz"
            echo "  laravel-setup ${setup_flags[*]:-}"
            exit 1
        }

        echo ""
        echo "Created Laravel app: $name"
        echo ""
        echo "  App:     https://${name}.exe.xyz"
        echo "  SSH:     ssh ${name}.exe.xyz"
        echo "  Shelley: https://${name}.exe.xyz:9999/"
        echo ""
        echo "Your app is live. SSH in and start building:"
        echo "  ssh ${name}.exe.xyz"
        echo ""
        echo "Code is at /home/exedev/app. Changes are immediately live."
        echo "See AGENTS.md in the app root for environment details."
        ;;
    list)
        result=$(ssh exe.dev ls --json)
        echo "$result" | jq -r ".vms[] | select(.vm_name != \"$TEMPLATE_VM\") | \"\(.vm_name)\t\(.status)\thttps://\(.vm_name).exe.xyz\"" | column -t -s $'\t'
        ;;
    ssh)
        name="${1:?Usage: exe-laravel ssh <name>}"
        ssh "${name}.exe.xyz"
        ;;
    open)
        name="${1:?Usage: exe-laravel open <name>}"
        open "https://${name}.exe.xyz" 2>/dev/null || xdg-open "https://${name}.exe.xyz" 2>/dev/null || echo "https://${name}.exe.xyz"
        ;;
    share)
        name="${1:?Usage: exe-laravel share <name>}"
        ssh exe.dev share set-public "$name"
        echo "App is now public: https://${name}.exe.xyz"
        ;;
    unshare)
        name="${1:?Usage: exe-laravel unshare <name>}"
        ssh exe.dev share set-private "$name"
        echo "App is now private: https://${name}.exe.xyz"
        ;;
    destroy)
        name="${1:?Usage: exe-laravel destroy <name>}"
        read -p "Delete VM '$name' and all its data? [y/N] " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            ssh exe.dev rm "$name"
            echo "Deleted: $name"
        else
            echo "Cancelled."
        fi
        ;;
    clone)
        name="${1:?Usage: exe-laravel clone <name> [new-name]}"
        new_name="${2:-}"
        if [[ -n "$new_name" ]]; then
            ssh exe.dev cp "$name" "$new_name"
        else
            ssh exe.dev cp "$name"
        fi
        ;;
    logs)
        name="${1:?Usage: exe-laravel logs <name>}"
        ssh "${name}.exe.xyz" tail -f /home/exedev/app/storage/logs/laravel.log
        ;;
    artisan)
        name="${1:?Usage: exe-laravel artisan <name> <command...>}"
        shift
        ssh "${name}.exe.xyz" "cd /home/exedev/app && php artisan $*"
        ;;
    agent)
        name="${1:?Usage: exe-laravel agent <name>}"
        open "https://${name}.exe.xyz:9999/" 2>/dev/null || xdg-open "https://${name}.exe.xyz:9999/" 2>/dev/null || echo "https://${name}.exe.xyz:9999/"
        ;;
    *) echo "Unknown command: $cmd"; usage; exit 1 ;;
esac
